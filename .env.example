# The worker authenticates through the ambient `claude` CLI login (recommended)
# or an explicit API key. If you have neither, run `claude` once to log in.
# ANTHROPIC_API_KEY=sk-ant-...

# Driving model for the worker (default: claude-sonnet-4-6).
# MODEL=claude-sonnet-4-6

# Where the worker controls a real Chrome (a dedicated debug-port instance,
# NOT your everyday browser). Start one with: scripts/chrome.sh start
# CDP_URL=http://127.0.0.1:9222

# The target web app the worker operates. For the demo this is the mock gym.
# TARGET_URL=http://127.0.0.1:5180

# Directory of SOP markdown files the worker is mandated to follow.
# SOP_DIR=./inputs/sops

# Vendored browser-harness checkout (driven via `uv run`).
# HARNESS_DIR=./vendor/browser-harness
